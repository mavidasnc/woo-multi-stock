# ── OS & Editor ───────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# JetBrains IDEs (PhpStorm, IntelliJ)
.idea/
*.iml

# VS Code
.vscode/
*.code-workspace

# Sublime Text
*.sublime-project
*.sublime-workspace

# ── PHP / Composer ────────────────────────────────────────────────────────────
vendor/
composer.lock

# ── Node / npm ────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ── Build output ──────────────────────────────────────────────────────────────
# If a build step is added in the future (e.g. minification, Sass)
dist/
build/
*.min.js
*.min.css

# ── Logs & temporary files ────────────────────────────────────────────────────
*.log
*.tmp
*.temp
*.bak
*.swp
*.swo

# ── WordPress-specific ────────────────────────────────────────────────────────
# Never commit WordPress core or other plugins/themes to this repo.
wp-admin/
wp-includes/
wp-content/uploads/
wp-content/plugins/
wp-content/themes/

# wp-config.php may contain database credentials — never commit it.
wp-config.php
wp-config-local.php

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.cert

# ── PHPUnit & testing ─────────────────────────────────────────────────────────
.phpunit.cache/
.phpunit.result.cache
coverage/
tests/_output/

# ── WordPress plugin release artefacts ───────────────────────────────────────
# SVN-style release folders used by the WP.org plugin repository
trunk/
tags/
branches/
